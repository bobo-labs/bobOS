{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": {
    "web": {
      "autoDeploy": true,
      "build": {
        "watch": ["apps/web/**", "packages/**"],
        "buildCommand": "pnpm run build --filter web"
      },
      "deploy": {
        "startCommand": "cd apps/web && pnpm start"
      }
    },
    "agent": {
      "autoDeploy": true,
      "build": {
        "watch": ["apps/agent/**", "packages/**"],
        "buildCommand": "pnpm run build --filter agent"
      },
      "deploy": {
        "startCommand": "cd apps/agent && pnpm start"
      }
    }
  }
}
